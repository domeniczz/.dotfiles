#!/usr/bin/env bash

set -euo pipefail

# ------------------------------------------------------------------------------
# Search through the whole system with persistent index
# and perform actions (preview, open, delete)
# ------------------------------------------------------------------------------

export LC_ALL=C

declare -gr INCLUDED_DIRS=(
    "/home"
    "/etc"
    "/var"
    "/srv"
    "/usr"
    "/opt"
)

declare -gr EXCLUDED_DIRS_FD=(
    ".git"
    ".venv"
    "node_modules"
    "__pycache__"
    "*/.cache/go/"
    "*/.cache/go-build/"
    "*/.local/share/Trash/"
)

declare -gr EXCLUDED_DIRS_FIND=(
    "*/\.git*"
    "*/\.venv*"
    "*/node_modules*"
    "*/__pycache__*"
    "*/\.cache/go*"
    "*/\.local/share/Trash*"
)

declare -gA OPENER_CONFIG=(
    ["directory"]="tui:${FILE_MANAGER:-vifm}:single"
    ["text"]="tui:nvim:batch"
    ["document"]="gui:zathura:batch"
    ["office"]="gui:libreoffice:batch"
    ["image"]="gui:imv:batch"
    ["video"]="gui:mpv:batch"
    ["audio"]="gui:mpv:batch"
    ["other"]="gui:xdg-open:single"
)

declare -gr INDEX_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/search"
declare -gr INDEX_FILE="$INDEX_DIR/index"
declare -gr PLAIN_INDEX_FILE="$INDEX_DIR/plain_index"
declare -gr LOCK_FILE="${TMPDIR:-/tmp}/search.lock"
declare -gr RELOAD_FLAG="$INDEX_DIR/.needs_reload"
declare -gr SOCKET_FILE="${XDG_RUNTIME_DIR:-${TMPDIR:-/tmp}}/search-server.sock"
declare -gr PID_FILE="${XDG_RUNTIME_DIR:-${TMPDIR:-/tmp}}/search-server.pid"
declare -gr FZF_LISTEN_SOCK="${XDG_RUNTIME_DIR:-${TMPDIR:-/tmp}}/search-fzf.sock"

declare -g TMP_DIR=""
declare -g SERVER_MODE=""

declare -g ENABLE_COLORS=1
declare -g ENABLE_SINGLETON=1
declare -g SEARCH_CLEAR_STATE_ON_DETACH=1

declare -g FIND_CMD=""

declare -g NEEDS_INDEX_REBUILD=0
declare -g FORCE_INDEX_REBUILD=0
declare -g INDEX_ALL=0

declare -gr RESOLVE_SYMLINK=0

declare -g SEARCH_QUERY=""

if command -v mawk >/dev/null 2>&1; then
    declare -gr AWK="mawk -W posix"
elif command -v gawk >/dev/null 2>&1; then
    declare -gr AWK="gawk --characters-as-bytes"
elif command -v awk >/dev/null 2>&1; then
    declare -gr AWK="awk"
else
    echo "AWK interpreter does not exists!" >&2
    exit 1
fi

if command -v rg >/dev/null 2>&1; then
    declare -gr GREP="rg --no-config --no-line-number"
elif command -v grep >/dev/null 2>&1; then
    declare -gr GREP="grep"
else
    echo "Grep does not exists!" >&2
    exit 1
fi

# ------------------------------------------------------------------------------
# Parse arguments
# ------------------------------------------------------------------------------

function print_usage() {
    cat << 'EOF'
Usage: search [OPTIONS]

Search through the whole system with persistent index and perform actions
(preview, open, delete) using an interactive fuzzy finder interface

OPTIONS:
    -s, --search       Search query
    -c, --color        Enable colored output (default)
    -nc, --nocolor     Disable colored output
    -r, --rebuild      Force rebuild of the search index
    -a, --all          Index literally all files
    -o, --singleton    Run only one instance of the script
    -m, --multi        Run multiple instances of the script
    -d, --daemon       Start search server (pre-warms and run in background)
    -q, --stop         Stop the search server
    -R, --restart      Restart the search server
    -S, --status       Show search server status
    -h, --help         Show this help message and exit

INTERACTIVE KEYS:
    Enter              Open selected item(s)
    Ctrl-o             Open parent directory of selected item
    Ctrl-x / F9        Delete selected item(s)
    Ctrl-r             Rebuild search index
    Ctrl-q             Disconnect from server (server mode only)

EXAMPLES:
    search
    search --rebuild
    search --nocolor
    search --server
EOF
}

ACTION_MODE=""
ACTION_ITEMS=()

while (( $# > 0 )); do
    case $1 in
        --)
            shift
            break
            ;;
        --search=*|-s=*)
            SEARCH_QUERY="${1#*=}"
            shift
            ;;
        --search|-s)
            shift
            if (( $# > 0 )); then
                SEARCH_QUERY="$1"
                shift
            else
                echo "Error: --search requires an argument" >&2
                exit 1
            fi
            ;;
        --color|-c)
            ENABLE_COLORS=1
            shift
            ;;
        --nocolor|-nc)
            ENABLE_COLORS=0
            shift
            ;;
        --rebuild|-r)
            FORCE_INDEX_REBUILD=1
            shift
            ;;
        --all|-a)
            INDEX_ALL=1
            shift
            ;;
        --singleton|-o)
            ENABLE_SINGLETON=1
            shift
            ;;
        --multi|-m)
            ENABLE_SINGLETON=0
            shift
            ;;
        --daemon|-d)
            SERVER_MODE="start"
            shift
            ;;
        --stop|-q)
            SERVER_MODE="stop"
            shift
            ;;
        --restart|-R)
            SERVER_MODE="restart"
            shift
            ;;
        --status|-S)
            SERVER_MODE="status"
            shift
            ;;
        --help|-h)
            print_usage
            exit 0
            ;;
        --server-run)
            SERVER_MODE="run"
            shift
            ;;
        --action-rebuild)
            ACTION_MODE="rebuild"
            shift
            ;;
        --action-open)
            ACTION_MODE="open"
            shift
            while (( $# > 0 )) && [[ "$1" != --* ]]; do
                ACTION_ITEMS+=("$1")
                shift
            done
            ;;
        --action-open-parent)
            ACTION_MODE="open-parent"
            shift
            while (( $# > 0 )) && [[ "$1" != --* ]]; do
                ACTION_ITEMS+=("$1")
                shift
            done
            ;;
        --action-delete)
            ACTION_MODE="delete"
            shift
            while (( $# > 0 )) && [[ "$1" != --* ]]; do
                ACTION_ITEMS+=("$1")
                shift
            done
            ;;
        *)
            shift
            ;;
    esac
done

# ------------------------------------------------------------------------------
# Build index
# ------------------------------------------------------------------------------

function build_index() {
    echo "Building index..."
    mkdir -p "$INDEX_DIR"

    if (( ENABLE_COLORS )); then
        eval "$FIND_CMD" | sort | tee "$INDEX_FILE" | \
        $AWK '{ gsub("\033\\[[0-9;]*m", ""); print }' > "$PLAIN_INDEX_FILE" || true
    else
        rm -f "$PLAIN_INDEX_FILE"
        eval "$FIND_CMD" | sort > "$INDEX_FILE" || true
    fi

    local count=$(wc -l < "$INDEX_FILE")
    echo "Index built successfully with $count entries."
}

function check_index() {
    NEEDS_INDEX_REBUILD=0
    if (( FORCE_INDEX_REBUILD )); then
        NEEDS_INDEX_REBUILD=1
        return 0
    fi
    if [[ ! -f "$INDEX_FILE" ]]; then
        NEEDS_INDEX_REBUILD=1
        return 0
    fi
    if (( ENABLE_COLORS )); then
        if [[ ! -f "$PLAIN_INDEX_FILE" ]] \
            || (( $(wc -l < "$INDEX_FILE") != $(wc -l < "$PLAIN_INDEX_FILE") )) \
            || ! $GREP --quiet --color=never $'\033\\[[0-9;]*m' "$INDEX_FILE"; then
            NEEDS_INDEX_REBUILD=1
        fi
    else
        if $GREP --quiet --color=never $'\033\\[[0-9;]*m' "$INDEX_FILE"; then
            NEEDS_INDEX_REBUILD=1
        fi
    fi
}

# ------------------------------------------------------------------------------
# Open item
# ------------------------------------------------------------------------------

function open_items() {
    local -a items=("$@")
    (( ${#items[@]} == 0 )) && return 0

    if (( ${#items[@]} > 1 )); then
        HAS_OUTPUT=1
        if ! select_items_to_open items; then
            return 0
        fi
    fi

    local -a existing=()
    local -a stale=()
    for item in "${items[@]}"; do
        if [[ -e "$item" || -L "$item" ]]; then
            existing+=("$item")
        else
            stale+=("$item")
        fi
    done

    (( ${#stale[@]} > 0 )) && remove_stale_entries "${stale[@]}"
    (( ${#existing[@]} == 0 )) && return 0

    local -A type_groups
    for item in "${existing[@]}"; do
        local parsed_item
        parsed_item="$(parse_item "$item")" || continue
        local item_type="$(classify_item "$parsed_item")"

        if [[ -n "${type_groups[$item_type]:-}" ]]; then
            type_groups[$item_type]+=$'\n'"$parsed_item"
        else
            type_groups[$item_type]="$parsed_item"
        fi
    done

    for item_type in "${!type_groups[@]}"; do
        local -a group_items
        IFS=$'\n' read -r -d '' -a group_items <<< "${type_groups[$item_type]}" || true
        execute_open "$item_type" "${group_items[@]}"
    done
}

function open_parents() {
    local -a items=("$@")
    (( ${#items[@]} == 0 )) && return 0

    if (( RESOLVE_SYMLINK )); then
        local -a resolved=()
        for item in "${items[@]}"; do
            if [[ -L "$item" ]]; then
                local target="$(readlink -f "$item")"
                [[ -e "$target" ]] && item="$target"
            fi
            resolved+=("$item")
        done
        items=("${resolved[@]}")
    fi

    local -a parents=()
    if (( ${#items[@]} > 1 )); then
        HAS_OUTPUT=1
        if ! select_parents_to_open items; then
            return 0
        fi
        parents=("${items[@]}")
    else
        parents=("$(dirname "${items[0]}")")
    fi

    local -a existing=()
    local -a stale=()
    for parent in "${parents[@]}"; do
        if [[ -e "$parent" ]]; then
            existing+=("$parent")
        else
            stale+=("$parent")
        fi
    done

    (( ${#stale[@]} > 0 )) && remove_stale_entries "${stale[@]}"

    for parent in "${existing[@]}"; do
        execute_open "directory" "$parent"
    done
}

function parse_number_selection() {
    local -n source_ref=$1
    local -n result_ref=$2
    local max=${#source_ref[@]}

    echo "Enter item numbers to open (e.g., '1 3 5' or '1-3 5'), or 'q' to quit:"
    read -r selection
    [[ "${selection,,}" == "q" ]] && return 1

    for part in $selection; do
        if [[ "$part" =~ ^[0-9]+$ ]]; then
            if (( part > 0 && part <= max )); then
                result_ref+=("${source_ref[$(( part - 1 ))]}")
            fi
        elif [[ "$part" =~ ^([0-9]+)-([0-9]+)$ ]]; then
            local start="${BASH_REMATCH[1]}" end="${BASH_REMATCH[2]}"
            for (( j = start; j <= end && j <= max; j++ )); do
                (( j > 0 )) && result_ref+=("${source_ref[$(( j - 1 ))]}")
            done
        fi
    done
}

function select_items_to_open() {
    local -n items_ref=$1
    local -a selected_items=()

    echo "You have selected ${#items_ref[@]} items:"
    local i
    for (( i = 0; i < ${#items_ref[@]}; i++)); do
        printf "  %2d. %s\n" $(( i + 1 )) "${items_ref[$i]}"
    done
    echo ""

    local choice
    choice=$(prompt_for_choice "Open all items? (y/s/q): " "ysq")
    [[ "$choice" == "q" ]] && return 1

    if [[ "$choice" == "y" ]]; then
        selected_items=("${items_ref[@]}")
    elif [[ "$choice" == "s" ]]; then
        parse_number_selection items_ref selected_items || return 1
    fi

    items_ref=("${selected_items[@]}")
    return 0
}

function select_parents_to_open() {
    local -n items_ref=$1
    local -A parent_map
    local -a unique_parents=()

    local -a parents
    readarray -t parents < <(dirname -- "${items_ref[@]}")
    local i
    for (( i = 0; i < ${#items_ref[@]}; i++ )); do
        local parent="${parents[$i]}"
        local item="${items_ref[$i]}"
        if [[ -z "${parent_map[$parent]:-}" ]]; then
            unique_parents+=("$parent")
            parent_map[$parent]="$item"
        else
            parent_map[$parent]+=$'\n'"$item"
        fi
    done

    echo "You have selected ${#items_ref[@]} items from ${#unique_parents[@]} directories:"
    for (( i = 0; i < ${#unique_parents[@]}; i++ )); do
        local parent="${unique_parents[$i]}"
        local count=$(echo "${parent_map[$parent]}" | wc -l)
        if (( count > 1 )); then
            printf "  %2d. %s (%d items)\n" $(( i + 1 )) "$parent" "$count"
        else
            printf "  %2d. %s\n" $(( i + 1 )) "$parent"
        fi
    done
    echo ""

    local choice
    choice=$(prompt_for_choice "Open all directories? (y/s/q): " "ysq")
    [[ "$choice" == "q" ]] && return 1

    local -a selected_parents=()

    if [[ "$choice" == "y" ]]; then
        selected_parents=("${unique_parents[@]}")
    elif [[ "$choice" == "s" ]]; then
        parse_number_selection unique_parents selected_parents || return 1
    fi

    items_ref=("${selected_parents[@]}")
    return 0
}

function mark_index_changed() {
    touch "$RELOAD_FLAG"
}

function parse_item() {
    local item="$1"

    if [[ -L "$item" ]]; then
        local target="$(readlink -f "$item")"
        if [[ ! -e "$target" ]]; then
            echo "Error: Symlink target does not exist: $item -> $target" >&2
            delete_item "$item" >&2
            HAS_OUTPUT=1
            return 1
        fi
        if (( RESOLVE_SYMLINK )); then
            echo "$target"
        else
            echo "$item"
        fi
        return 0
    fi

    echo "$item"
    return 0
}

function remove_stale_entries() {
    (( $# == 0 )) && return 0
    HAS_OUTPUT=1
    echo "The following item(s) no longer exist:"
    printf "  - %s\n" "$@"
    echo ""
    local confirm
    read -r -p "Remove from index? (y/n): " confirm
    if [[ "${confirm:-n}" =~ ^[Yy]$ ]]; then
        local to_remove=("$@")
        for item in "$@"; do
            append_nested_entries "$item" to_remove
        done
        delete_from_index "${to_remove[@]}"
        mark_index_changed
        echo "Item(s) removed from index."
    fi
}

function classify_item() {
    local item="$1"
    [[ -L "$item" ]] && item="$(readlink -f "$item")"
    if [[ -d "$item" ]]; then
        echo "directory"
        return 0
    fi
    local mime_type=$(file --brief --mime-type "$item" || echo "unknown")
    case "$mime_type" in
        text/*|application/json|application/xml|application/x-tex|application/toml|application/x-yaml|application/javascript|application/x-sh|application/x-shellscript|inode/x-empty|application/x-empty|application/x-zerosize)
            echo "text"
            ;;
        application/pdf|application/epub+zip)
            echo "document"
            ;;
        application/*.opendocument.*|application/vnd.openxmlformats-officedocument.*|application/msword|application/vnd.ms-word*|application/vnd.ms-excel*|application/vnd.ms-powerpoint*)
            echo "office"
            ;;
        image/*)
            echo "image"
            ;;
        video/*|application/vnd.rn-realmedia)
            echo "video"
            ;;
        audio/*)
            echo "audio"
            ;;
        *)
            echo "other"
            ;;
    esac
}

function execute_open() {
    local item_type="$1"
    shift
    local -a items=("$@")

    local config="${OPENER_CONFIG[$item_type]:-gui:xdg-open:single}"
    IFS=':' read -r ui app multi <<< "$config"

    if [[ "$ui" == "gui" ]] && ! check_gui; then
        echo "No GUI support detected for $item_type files." >&2
        return 1
    fi

    local app_name="${app%% *}"
    if ! command -v "$app_name" >/dev/null 2>&1; then
        echo "$app_name does not exist." >&2
        read -r -p "Press Enter to continue..."
        return 1
    fi

    if [[ "$multi" == "batch" ]]; then
        local cmd="$app"
        local cwd=""
        for item in "${items[@]}"; do
            cmd+=" $(printf "%q" "$item")"
            if [[ -z "$cwd" ]]; then
                [[ -d "$item" ]] && cwd="$item" || cwd="$(dirname "$item")"
            fi
        done
        dispatch_command "$ui" "$cmd" "$cwd"
    else
        for item in "${items[@]}"; do
            local cwd
            [[ -d "$item" ]] && cwd="$item" || cwd="$(dirname "$item")"
            dispatch_command "$ui" "$app $(printf "%q" "$item")" "$cwd"
        done
    fi
}

function dispatch_command() {
    local ui="$1"
    local cmd="$2"
    local cwd="${3:-}"

    case "$ui" in
        tui)
            if [[ -n "$cwd" ]]; then
                cmd="cd $(printf %q "$cwd") && $cmd"
            fi
            if [[ -n "${TMUX:-}" ]]; then
                LC_ALL="" tmux new-window "$cmd"
            elif [[ -n "${STY:-}" ]]; then
                LC_ALL="" screen -S "$STY" -X screen "$cmd"
            else
                LC_ALL="" sh -c "$cmd"
            fi
            ;;
        gui)
            { LC_ALL="" sh -c "$cmd" >/dev/null 2>&1 & } || true
            ;;
    esac
}

# ------------------------------------------------------------------------------
# Delete item
# ------------------------------------------------------------------------------

function delete_item() {
    (( $# == 0 )) && return 0

    echo "Do you want to delete the following $# item(s)?"
    printf "  - %s\n" "$@"

    local confirm
    read -r -p "Proceed with deletion? (y/n): " confirm

    if [[ "${confirm:-n}" =~ ^[Yy]$ ]]; then
        local to_remove=()
        local dirs_to_delete=()
        local files_to_delete=()

        for item in "$@"; do
            to_remove+=("$item")
            if [[ -L "$item" ]]; then
                files_to_delete+=("$item")
                append_nested_entries "$item" to_remove
            elif [[ ! -e "$item" ]]; then
                echo "Warning: $item no longer exists, removing from index only."
                append_nested_entries "$item" to_remove
            elif [[ -d "$item" ]]; then
                dirs_to_delete+=("$item")
                append_nested_entries "$item" to_remove
            else
                files_to_delete+=("$item")
            fi
        done

        (( ${#files_to_delete[@]} > 0 || ${#dirs_to_delete[@]} > 0 )) && {
            echo "Removing item(s)..."
            (( ${#files_to_delete[@]} > 0 )) && rm -f "${files_to_delete[@]}"
            (( ${#dirs_to_delete[@]} > 0 )) && rm -rf "${dirs_to_delete[@]}"
        }

        if (( ${#to_remove[@]} > 0 )); then
            local lines_before=$(wc -l < "$INDEX_FILE")
            echo "Updating index..."
            delete_from_index "${to_remove[@]}"
            local lines_after=$(wc -l < "$INDEX_FILE")
            if (( lines_before != lines_after )); then
                mark_index_changed
                echo "Index updated."
            else
                echo "Nothing to update in index."
            fi
            echo "Deletion completed."
        fi

        read -r -p "Press Enter to continue..."
    else
        echo "Deletion cancelled."
    fi
}

function find_nested_entries() {
    local dir="$1"
    [[ "$dir" != */ ]] && dir="${dir}/"
    local index="$INDEX_FILE"
    (( ENABLE_COLORS )) && index="$PLAIN_INDEX_FILE"
    $AWK -v prefix="$dir" 'substr($0, 1, length(prefix)) == prefix' "$index"
}

function append_nested_entries() {
    local item="$1"
    local -n arr_ref="$2"
    local nested=$(find_nested_entries "$item")
    if [[ -n "$nested" ]]; then
        while IFS= read -r entry; do
            arr_ref+=("$entry")
        done <<< "$nested"
    fi
}

function delete_from_index() {
    (( $# == 0 )) && return 0

    [[ -z "$TMP_DIR" ]] && TMP_DIR="$(mktemp -d "${TMPDIR:-/tmp}/search_XXXXXXXXXX")"
    local tmp_index_file="$TMP_DIR/index_filtered"
    local tmp_plain_index_file="$TMP_DIR/plain_index_filtered"
    local exclude_file="$TMP_DIR/exclude_list"

    printf "%s\n" "$@" > "$exclude_file"

    if (( ! ENABLE_COLORS )); then
        if (( $# < 5000 )); then
            $GREP --invert-match --fixed-strings --line-regexp --file "$exclude_file" "$INDEX_FILE" > "$tmp_index_file" || true
        else
            $AWK '
            BEGIN {
                while ((getline line < "'$exclude_file'") > 0) {
                    exclude[line] = 1
                }
                close("'$exclude_file'")
            }
            !($0 in exclude)
            ' "$INDEX_FILE" > "$tmp_index_file"
        fi

        mv "$tmp_index_file" "$INDEX_FILE"
    else
        $AWK '
        BEGIN {
            while ((getline line < "'$exclude_file'") > 0) {
                exclude[line] = 1
            }
            close("'$exclude_file'")
        }
        {
            if ((getline colored < "'$INDEX_FILE'") > 0) {
                if (!($0 in exclude)) {
                    print $0 > "'$tmp_plain_index_file'"
                    print colored > "'$tmp_index_file'"
                }
            }
        }' "$PLAIN_INDEX_FILE"

        mv "$tmp_index_file" "$INDEX_FILE"
        mv "$tmp_plain_index_file" "$PLAIN_INDEX_FILE"
    fi
}

# ------------------------------------------------------------------------------
# Utils
# ------------------------------------------------------------------------------

function construct_find_command() {
    local search_cmd=""

    if command -v fd >/dev/null 2>&1; then
        search_cmd="fd '' --hidden --no-ignore --absolute-path"
        if (( ! ENABLE_COLORS )); then
            search_cmd+=" --color=never"
        else
            search_cmd+=" --color=always"
        fi
        if (( INDEX_ALL != 0 )); then
            search_cmd+=" --search-path /"
        else
            for dir in "${INCLUDED_DIRS[@]}"; do
                search_cmd+=" --search-path \"${dir}\""
            done
            for dir in "${EXCLUDED_DIRS_FD[@]}"; do
                search_cmd+=" --exclude \"${dir}\""
            done
        fi
    else
        ENABLE_COLORS=0
        search_cmd="find -O2"
        if (( INDEX_ALL != 0 )); then
            search_cmd+=" /"
        else
            for dir in "${INCLUDED_DIRS[@]}"; do
                search_cmd+=" \"${dir}\""
            done
            for dir in "${EXCLUDED_DIRS_FIND[@]}"; do
                search_cmd+=" -path \"${dir}\" -prune -o"
            done
        fi
        search_cmd+=" -print"
    fi

    search_cmd+=" 2>/dev/null"
    FIND_CMD="$search_cmd"
}

function prompt_for_choice() {
    local prompt_text="$1"
    local valid_chars="$2"
    local choice

    while true; do
        read -r -p "$prompt_text" choice
        choice="${choice,,}"
        if (( ${#choice} == 1 )) && [[ "$valid_chars" == *"$choice"* ]]; then
            echo "$choice"
            return 0
        fi
        local display_opts=$(echo "$valid_chars" | sed 's/\(.\)/\1\//g; s/\/$//')
        echo "Invalid input. Please enter: $display_opts" >&2
    done
}

function select_command() {
    for cmd in "$@"; do
        if check_command_string "$cmd"; then
            printf "%s\n" "$cmd"
            return 0
        fi
    done

    printf "%s\n" "echo 'Cannot preview, command not exists'"
}

function construct_fzf_preview_command() {
    local dir_cmd=$(select_command \
        "eza -la --color=always {} 2>/dev/null" \
        "ls -la --color=always {} 2>/dev/null")

    local html_cmd=$(select_command \
        "w3m -dump -X -M -T text/html -no-mouse -no-graph -no-cookie {}" \
        "bat --color=always --style=plain --paging=never --wrap=never --line-range=:200 {} 2>/dev/null" \
        "cat {} 2>/dev/null")

    local text_cmd=$(select_command \
        "bat --color=always --style=plain --paging=never --wrap=never --line-range=:200 {} 2>/dev/null" \
        "cat {} 2>/dev/null")

    local json_cmd=$(select_command \
        "bat --color=always --style=plain --language json --paging=never --wrap=never --line-range=:200 <(jq . --monochrome-output --raw-output {} 2>/dev/null || cat {})" \
        "jq . --monochrome-output --raw-output {} 2>/dev/null || cat {}")

    local general_archive_cmd=$(select_command \
        "bsdtar -tvf {} | awk '{print \$6 \" \" \$7 \" \" \$8 \" - \" \$NF}' 2>/dev/null" \
        "7z l -ba {} | awk '{print \$1 \" \" \$2 \" - \" \$NF}' 2>/dev/null")

    local gzip_archive_cmd=$(select_command \
        "7z l -ba {} | awk '{print \$1 \" \" \$2 \" - \" \$NF}' 2>/dev/null" \
        "gzip -l {}")

    local pdf_cmd=$(select_command \
        "pdftotext -nopgbrk -l 3 {} - 2>/dev/null")

    local epub_cmd=$(select_command \
        "epub2txt {} - 2>/dev/null")

    local docx_cmd=$(select_command \
        "docx2txt {} - 2>/dev/null")

    local doc_cmd=$(select_command \
        "catdoc {} 2>/dev/null")

    local general_file_cmd=$(select_command \
        "file --brief {} 2>/dev/null")

    printf "%s" "
        function preview_file_content() {
            local file_path=\"\$1\"
            file_info=\$(stat --format='size: %s bytes, last modified: %y' \"\$file_path\" 2>/dev/null | cut -d. -f1)
            echo -e \"\$file_info\n\"
            local mime_type=\$(file --brief --mime-type \"\$file_path\" 2>/dev/null)
            case \"\$mime_type\" in
                text/html)
                    $html_cmd
                    ;;
                text/*|application/xml|application/javascript|application/x-sh|application/x-shellscript|application/x-tex|application/toml|application/x-yaml)
                    $text_cmd
                    ;;
                application/json)
                    $json_cmd
                    ;;
                application/zip|application/java-archive|application/x-rar|application/x-7z-compressed|application/x-tar|application/x-gzip|application/x-bzip2|application/x-xz|application/zstd)
                    $general_archive_cmd
                    ;;
                application/gzip)
                    $gzip_archive_cmd
                    ;;
                application/pdf)
                    $pdf_cmd
                    ;;
                application/epub+zip)
                    $epub_cmd
                    ;;
                application/vnd.openxmlformats-officedocument.*)
                    $docx_cmd
                    ;;
                application/msword)
                    $doc_cmd
                    ;;
                inode/x-empty|application/x-empty|application/x-zerosize)
                    echo 'empty file'
                    ;;
                *)
                    $general_file_cmd
                    ;;
            esac
        }

        if [[ -L {} ]]; then
            target=\$(readlink -f {} 2>/dev/null)
            if [[ -n \$target ]]; then
                echo \"symbolic link to \$target\n\"
                if [[ -d \$target ]]; then
                    dir_info=\$(stat --format='last modified: %y' \$target 2>/dev/null | cut -d. -f1)
                    echo -e \"\$dir_info\n\"
                    $dir_cmd
                elif [[ -e \$target ]]; then
                    preview_file_content \$target
                else
                    echo 'link target does not exist'
                fi
            else
                echo 'broken symbolic link'
            fi
        elif [[ -d {} ]]; then
            dir_info=\$(stat --format='last modified: %y' {} 2>/dev/null | cut -d. -f1)
            echo -e \"\$dir_info\n\"
            $dir_cmd
        else
            preview_file_content {}
        fi
    "
}

function check_command_string() {
    local cmd_string="$1"

    cmd_string="${cmd_string//&&/|}"
    cmd_string="${cmd_string//||/|}"

    if [[ "$cmd_string" != *'"'* && "$cmd_string" != *"'"* ]]; then
        IFS='|' read -ra pipeline_parts <<< "$cmd_string"
        for part in "${pipeline_parts[@]}"; do
            read -r cmd_name _ <<< "$part"
            if ! command -v "$cmd_name" >/dev/null 2>&1; then
                echo "$cmd_name does not exists." >&2
                return 1
            fi
        done
        return 0
    fi

    local commands=()
    local current_cmd=""
    local in_single_quote=0
    local in_double_quote=0
    local escaped=0

    for (( i = 0; i < ${#cmd_string}; i++ )); do
        local char="${cmd_string:$i:1}"

        if (( escaped )); then
            current_cmd+="$char"
            escaped=0
            continue
        fi

       case "$char" in
            "\\")
                if (( !in_single_quote )); then
                    escaped=1
                fi
                current_cmd+="$char"
                ;;
            "'")
                if (( !in_double_quote )); then
                    (( in_single_quote = !in_single_quote ))
                fi
                current_cmd+="$char"
                ;;
            '"')
                if (( !in_single_quote )); then
                    (( in_double_quote = !in_double_quote ))
                fi
                current_cmd+="$char"
                ;;
            "|")
                if (( !in_single_quote && !in_double_quote )); then
                    [[ -n "${current_cmd// }" ]] && commands+=("$current_cmd")
                    current_cmd=""
                else
                    current_cmd+="$char"
                fi
                ;;
            *)
                current_cmd+="$char"
                ;;
        esac
    done

    [[ -n "${current_cmd// }" ]] && commands+=("$current_cmd")

    for part in "${commands[@]}"; do
        read -r cmd_name _ <<< "$part"
        if ! command -v "$cmd_name" >/dev/null 2>&1; then
            echo "$cmd_name does not exists." >&2
            return 1
        fi
    done

    return 0
}

function run_fzf() {
    local mode="$1"

    local preview_cmd="$(construct_fzf_preview_command)"
    local self="$(readlink -f "$0")"
    (( ENABLE_COLORS == 0 )) && self+=" --nocolor"

    local reload="+transform([[ -f $RELOAD_FLAG ]] && rm -f $RELOAD_FLAG && echo 'reload:cat $INDEX_FILE')"

    local -a args=(
        --ansi --smart-case --tabstop=4 --no-cycle --border=none --footer-border=none --multi --highlight-line
        --preview="$preview_cmd" --preview-window='right,50%,border-left,nocycle,nowrap'
        --prompt='❯ '
        --bind='focus:transform-header:stat --printf="%A %U:%G" {} || echo "---"'
        --bind='Esc:ignore'
        --bind='Ctrl-n:down,Ctrl-p:up'
        --bind='Ctrl-e:offset-down,Ctrl-y:offset-up'
        --bind='Ctrl-d:half-page-down,Ctrl-u:half-page-up'
        --bind='Ctrl-f:page-down,Ctrl-b:page-up'
        --bind='Ctrl-j:preview-half-page-down,Ctrl-k:preview-half-page-up'
        --bind='Ctrl-/:toggle-preview'
        --bind='Ctrl-s:deselect-all'
        --bind="Enter:execute($self --action-open {+})$reload"
        --bind="Ctrl-o:execute($self --action-open-parent {+})$reload"
        --bind="Ctrl-x:execute($self --action-delete {+})$reload"
        --bind="F9:execute($self --action-delete {+})$reload"
        --bind="Ctrl-r:execute($self --action-rebuild)+reload(cat $INDEX_FILE)"
        --bind="Alt-r:reload(cat $INDEX_FILE)"
        --bind="F1:preview($self --help)"
    )

    if [[ "$mode" == "server" ]]; then
        rm -f "$FZF_LISTEN_SOCK"
        args+=(
            --listen "$FZF_LISTEN_SOCK"
            --footer='Enter: open, Ctrl-o: open parent, Ctrl-x / F9: delete, Ctrl-r: rebuild index, Ctrl-q: disconnect'
            --bind='Ctrl-q:abort'
            --bind='Ctrl-c:clear-query'
        )
    else
        args+=(
            --query="$SEARCH_QUERY"
            --footer='Enter: open, Ctrl-o: open parent, Ctrl-x / F9: delete, Ctrl-r: rebuild index, F1: help'
            --bind='Ctrl-q:abort,Ctrl-c:abort'
        )
    fi

    fzf "${args[@]}" < "$INDEX_FILE"
}

function get_detach_reset_action() {
    if (( SEARCH_CLEAR_STATE_ON_DETACH )); then
        printf '%s' 'change-query()+clear-selection+first'
    fi
}

function check_gui() {
    [[ -n "${WAYLAND_DISPLAY:-}" ]] || \
    [[ -n "${DISPLAY:-}" ]] || \
    [[ "${XDG_SESSION_TYPE:-}" == "wayland" ]] || \
    [[ "${XDG_SESSION_TYPE:-}" == "x11" ]]
}

function running_instance_check() {
    exec 200>"$LOCK_FILE"
    if (( ENABLE_SINGLETON == 1 )) && ! flock -n 200; then
        echo "Another instance of the script is already running." >&2
        read -r -p "Press Enter to continue..."
        exit 1
    fi
}

# ------------------------------------------------------------------------------
# Traps
# ------------------------------------------------------------------------------

function cleanup() {
    [[ -n "$TMP_DIR" ]] && rm -rf "$TMP_DIR"
    # Only the main process should clean up shared resources
    if [[ -z "$ACTION_MODE" ]] && [[ "$SERVER_MODE" != "run" ]]; then
        rm -f "$LOCK_FILE" "$RELOAD_FLAG"
        if command -v fd >/dev/null 2>&1; then
            fd --type d --regex '^search_[a-zA-Z0-9]{10}$' "${TMPDIR:-/tmp}" --max-depth 1 --exec rm -rf '{}' ';' 2>/dev/null || true
        else
            find "${TMPDIR:-/tmp}" -maxdepth 1 -type d -regextype posix-extended -regex ".*/search_[a-zA-Z0-9]{10}" -exec rm -rf '{}' \; 2>/dev/null || true
        fi
    fi
}

trap cleanup EXIT INT TERM QUIT PIPE

# ------------------------------------------------------------------------------
# Action handler for fzf execute
# ------------------------------------------------------------------------------

function action_handler() {
    HAS_OUTPUT=0
    case "$ACTION_MODE" in
        rebuild)
            construct_find_command
            build_index
            print_separator
            ;;
        open)
            open_items "${ACTION_ITEMS[@]}"
            (( HAS_OUTPUT )) && print_separator
            ;;
        open-parent)
            open_parents "${ACTION_ITEMS[@]}"
            (( HAS_OUTPUT )) && print_separator
            ;;
        delete)
            delete_item "${ACTION_ITEMS[@]}"
            print_separator
            ;;
    esac
}

function print_separator() {
    echo "------------------------------------------------------------"
}

if [[ -n "$ACTION_MODE" ]]; then
    action_handler
    exit 0
fi

# ------------------------------------------------------------------------------
# Server mode
# ------------------------------------------------------------------------------

function server_is_running() {
    local pid
    [[ -S "$SOCKET_FILE" ]] && [[ -f "$PID_FILE" ]] && read -r pid < "$PID_FILE" && kill -0 "$pid" 2>/dev/null
}

function server_start() {
    if server_is_running; then
        echo "Server already running." >&2
        return 0
    fi
    if ! command -v abduco >/dev/null 2>&1; then
        echo "abduco is required for server mode. Install: pacman -S abduco" >&2
        return 1
    fi
    construct_find_command
    check_index
    (( NEEDS_INDEX_REBUILD )) && build_index
    rm -f "$SOCKET_FILE"
    local -a cmd=("$(readlink -f "$0")" --server-run)
    (( ENABLE_COLORS == 0 )) && cmd+=(--nocolor)
    abduco -n "$SOCKET_FILE" "${cmd[@]}"
    echo "Search server started."
}

function server_stop() {
    if [[ -f "$PID_FILE" ]]; then
        local pid abduco_pid
        { read -r pid; read -r abduco_pid; } < "$PID_FILE" || true
        if [[ -n "${pid:-}" ]] && kill -0 "$pid" 2>/dev/null; then
            kill "$pid" 2>/dev/null || true
            [[ -n "${abduco_pid:-}" ]] && kill "$abduco_pid" 2>/dev/null || true
            rm -f "$PID_FILE" "$SOCKET_FILE"
            echo "Search server stopped."
            return
        fi
    fi
    rm -f "$PID_FILE" "$SOCKET_FILE"
    echo "No server running."
}

function server_restart() {
    server_stop
    server_start
}

function server_status() {
    if server_is_running; then
        local pid
        read -r pid < "$PID_FILE"
        echo "Server: running (PID $pid)"
        echo "Socket: $SOCKET_FILE"
    else
        echo "Server: not running"
    fi
    if [[ -f "$INDEX_FILE" ]]; then
        local count
        count=$(wc -l < "$INDEX_FILE")
        local mod
        mod=$(stat --format='%y' "$INDEX_FILE" 2>/dev/null | cut -d. -f1)
        echo "Index:  $count entries ($INDEX_FILE)"
        echo "Built:  $mod"
    else
        echo "Index:  not built"
    fi
}

function server_run() {
    printf '%s\n%s\n' "$$" "$PPID" > "$PID_FILE"
    trap - TERM
    trap 'rm -f "$PID_FILE" "$FZF_LISTEN_SOCK"; [[ -n "$TMP_DIR" ]] && rm -rf "$TMP_DIR"' EXIT
    construct_find_command
    check_index
    (( NEEDS_INDEX_REBUILD )) && build_index
    rm -f "$RELOAD_FLAG"
    while true; do
        run_fzf "server" || true
        sleep 0.1
    done
}

case "$SERVER_MODE" in
    start)   server_start;   exit $? ;;
    stop)    server_stop;    exit 0 ;;
    restart) server_restart; exit $? ;;
    status)  server_status;  exit 0 ;;
    run)     server_run;     exit 0 ;;
esac

# ------------------------------------------------------------------------------
# Main function
# ------------------------------------------------------------------------------

function main() {
    if server_is_running; then
        abduco -e ^q -a "$SOCKET_FILE" || true
        local detach_reset_action="$(get_detach_reset_action)"
        if [[ -n "$detach_reset_action" ]] && [[ -S "$FZF_LISTEN_SOCK" ]]; then
            curl --unix-socket "$FZF_LISTEN_SOCK" -s -X POST localhost -d "$detach_reset_action" 2>/dev/null || true
        fi
        exit 0
    fi
    running_instance_check
    construct_find_command
    check_index
    (( NEEDS_INDEX_REBUILD )) && { build_index; print_separator; }
    rm -f "$RELOAD_FLAG"
    run_fzf "main"
}

main
